<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<!-- 게시글 CRUD 및 검색/페이징 쿼리 -->
<mapper namespace="com.human.board.mapper.BoardMapper">

    <!-- 게시글 + 첨부파일 목록 resultMap -->
    <resultMap id="boardWithFiles" type="BoardVo">
        <id     property="id"        column="id"/>
        <result property="writer"    column="writer"/>
        <result property="title"     column="title"/>
        <result property="content"   column="content"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedAt" column="updated_at"/>
        <result property="deleted"   column="deleted"/>
        <result property="savedName" column="saved_name"/>
        <collection property="flist" ofType="BoardFileVo" javaType="java.util.ArrayList">
            <id     property="id"           column="file_id"/>
            <result property="boardId"      column="board_id"/>
            <result property="originalName" column="original_name"/>
            <result property="savedName"    column="file_saved_name"/>
            <result property="filePath"     column="file_path"/>
            <result property="fileSize"     column="file_size"/>
            <result property="createdAt"    column="file_created_at"/>
        </collection>
    </resultMap>

    <!-- 검색 조건 공통 SQL: deleted=1(활성), 키워드 있으면 title/writer/all 중 선택 -->
    <sql id="searchCondition">
        AND deleted = 1
        <if test="keyword != null and keyword != ''">
            <choose>
                <when test="searchType == 'title'">
                    AND title LIKE CONCAT('%', #{keyword}, '%')
                </when>
                <when test="searchType == 'writer'">
                    AND writer LIKE CONCAT('%', #{keyword}, '%')
                </when>
                <otherwise>
                    AND (title LIKE CONCAT('%', #{keyword}, '%')
                      OR writer LIKE CONCAT('%', #{keyword}, '%'))
                </otherwise>
            </choose>
        </if>
    </sql>

    <!-- 전체 게시글 목록 조회 (최신순) -->
    <select id="selectAll" resultType="BoardVo">
        SELECT id, writer, title, content, created_at, updated_at, deleted
        FROM board
        WHERE deleted = 1
        ORDER BY id DESC
    </select>

    <!-- 검색 조건 + 페이징 적용 게시글 목록 조회 -->
    <select id="selectBySearch" parameterType="SearchVo" resultType="BoardVo">
        SELECT b.id, b.writer, b.title, b.content, b.created_at, b.updated_at, b.deleted,
               (SELECT bf.saved_name FROM board_file bf
                WHERE bf.board_id = b.id AND bf.deleted = 1
                ORDER BY bf.id ASC LIMIT 1) AS saved_name
        FROM board b
        WHERE 1=1
        <include refid="searchCondition"/>
        ORDER BY b.id DESC
        LIMIT #{size} OFFSET #{offset}
    </select>

    <!-- 검색 조건에 해당하는 전체 게시글 수 조회 (페이징 계산용) -->
    <select id="countBySearch" parameterType="SearchVo" resultType="int">
        SELECT COUNT(*)
        FROM board
        WHERE 1=1
        <include refid="searchCondition"/>
    </select>

    <!-- 게시글 단건 조회 (첨부파일 목록 포함) -->
    <select id="selectOne" parameterType="Long" resultMap="boardWithFiles">
        SELECT b.id, b.writer, b.title, b.content, b.created_at, b.updated_at, b.deleted,
               bf.id           AS file_id,
               bf.board_id,
               bf.original_name,
               bf.saved_name   AS file_saved_name,
               bf.file_path,
               bf.file_size,
               bf.created_at   AS file_created_at
        FROM board b
        LEFT JOIN board_file bf ON bf.board_id = b.id AND bf.deleted = 1
        WHERE b.id = #{id} AND b.deleted = 1
    </select>

    <!-- 게시글 등록 -->
    <insert id="insert" parameterType="BoardVo" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO board (writer, title, content)
        VALUES (#{writer}, #{title}, #{content})
    </insert>

    <!-- 게시글 제목/내용 수정 -->
    <update id="update" parameterType="BoardVo">
        UPDATE board
        SET title = #{title}, content = #{content}
        WHERE id = #{id}
    </update>

    <!-- 게시글 soft delete (deleted=0으로 변경) -->
    <update id="delete" parameterType="Long">
        UPDATE board
        SET deleted = 0
        WHERE id = #{id}
    </update>

</mapper>
